# Shelby Protocol (server-only secret, if Shelby faucet requires it)
SHELBY_API_KEY=

# Geomi / Aptos Labs API key (server-only; never prefix with PUBLIC_)
GEOMI_API_KEY=

# Browser-visible config (Astro exposes PUBLIC_* to client)
PUBLIC_SHELBY_API_KEY=
PUBLIC_SHELBY_RPC_URL=https://api.shelbynet.shelby.xyz/shelby
PUBLIC_SHELBY_EXPLORER_URL=https://explorer.shelby.xyz/shelbynet
PUBLIC_SITE_URL=http://localhost:4321

# ACE encryption / access-control config
PUBLIC_ACE_RPC_URL=https://api.testnet.aptoslabs.com/v1
PUBLIC_ACE_CONTRACT=
PUBLIC_ACE_KEYPAIR_ID=
PUBLIC_ACE_ACCESS_CONTROL_CONTRACT=
