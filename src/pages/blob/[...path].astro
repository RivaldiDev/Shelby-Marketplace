---
import Base from '../../layouts/Base.astro';
const path = Astro.params.path || '';
const [owner = '', ...nameParts] = path.split('/');
const name = decodeURIComponent(nameParts.join('/'));
const downloadUrl = `https://api.testnet.shelby.xyz/shelby/v1/blobs/${owner}/${encodeURIComponent(name)}`;
---
<Base title={`${name || 'Asset detail'} · Shelby Marketplace`}>
  <main class="section container">
    <span class="eyebrow">Asset detail</span>
    <h1>{name || 'Asset not found'}</h1>
    <div class="card glow">
      <span class="badge">Owner</span>
      <p class="code">{owner}</p>
      <span class="badge">Filename</span>
      <p class="code">{name}</p>
      <div class="actions">
        <a class="btn primary" href={downloadUrl} target="_blank">Open via Shelby RPC</a>
        <a class="btn" href="/browse">Back to marketplace</a>
      </div>
    </div>
  </main>
</Base>
